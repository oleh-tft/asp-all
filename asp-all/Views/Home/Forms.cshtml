@model asp_all.Models.Home.HomeFormsViewModel
@{
    ViewData["Title"] = "Forms";
    bool isInvalid;
    String validationClass, errorMessages, fieldName;
}
<div class="text-center">
    <h1 class="display-4">
        <i class="bi bi-card-checklist display-5"></i>
        Forms
    </h1>
</div>
<p>
    HTML-форми – інструментарій браузерів для надсилання даних до сервера.
    Параметри форми задають:
</p>
<ul>
    <li>
        адресу, куди надсилаються дані (action),
        або asp-тег-хелпери (asp-controller, asp-action, ...). Якщо
        ці параметри не зазначаються або лишаються порожніми, то дані форми
        передаються на поточну адресу;
    </li>
    <li>
        метод, яким надсилаються дані: get або post. Методом get дані включаються
        до URL, post – до тіла пакета;
    </li>
    <li>
        кодування даних форми: <code>application/x-www-form-urlencoded</code> (за
        замовчанням) – спосіб кодування для підстановки в URL,
        <code>multipart/form-data</code> – для розділення даних по різних частинах
        пакету – підходить для передачі файлів.
    </li>
</ul>

<form asp-action="FormsReceiver" method="post" enctype="multipart/form-data" class="border p-3">
    <div class="row">
        <div class="col">
            <div class="input-group mb-3">
                @{
                    fieldName = "user-name";
                    isInvalid = Model.FormModelState?.Keys.Contains(fieldName) ?? false;
                    validationClass = Model.FormModelState == null ? "" : isInvalid ? "is-invalid" : "is-valid";
                    errorMessages = isInvalid
                    ? String.Join(", ", Model.FormModelState![fieldName]!.Errors.Select(e => e.ErrorMessage))
                    : "";
                }
                <span class="input-group-text" id="user-name-addon"><i class="bi bi-person"></i></span>
                <input type="text" class="form-control @validationClass" name=@fieldName 
                       value="@Model.FormModel?.UserName"
                       placeholder="Name" aria-label="Name" aria-describedby="user-name-addon" />
                <div class="invalid-feedback">@errorMessages</div>
            </div>
        </div>
        <div class="col">
            <div class="input-group mb-3">
                @{
                    fieldName = "user-email";
                    isInvalid = Model.FormModelState?.Keys.Contains(fieldName) ?? false;
                    validationClass = Model.FormModelState == null ? "" : isInvalid ? "is-invalid" : "is-valid";
                    errorMessages = isInvalid
                    ? String.Join(", ", Model.FormModelState![fieldName]!.Errors.Select(e => e.ErrorMessage))
                    : "";
                }
                <span class="input-group-text" id="user-email-addon"><i class="bi bi-envelope-at"></i></span>
                <input type="email" class="form-control @validationClass" name=@fieldName
                       value="@Model.FormModel?.UserEmail"
                       placeholder="E-mail" aria-label="E-mail" aria-describedby="user-email-addon" />
                <div class="invalid-feedback">@errorMessages</div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col">
            <div class="input-group mb-3">
                @{
                    fieldName = "user-login";
                    isInvalid = Model.FormModelState?.Keys.Contains(fieldName) ?? false;
                    validationClass = Model.FormModelState == null ? "" : isInvalid ? "is-invalid" : "is-valid";
                    errorMessages = isInvalid
                    ? String.Join(", ", Model.FormModelState![fieldName]!.Errors.Select(e => e.ErrorMessage))
                    : "";
                }
                <span class="input-group-text" id="user-login-addon"><i class="bi bi-key"></i></span>
                <input type="text" class="form-control @validationClass" name=@fieldName
                       value="@Model.FormModel?.UserLogin"
                       placeholder="Login" aria-label="Login" aria-describedby="user-login-addon" />
                <div class="invalid-feedback">@errorMessages</div>
            </div>
        </div>
        <div class="col">
            <div class="input-group mb-3">
                @{
                    fieldName = "user-birthdate";
                    isInvalid = Model.FormModelState?.Keys.Contains(fieldName) ?? false;
                    validationClass = Model.FormModelState == null ? "" : isInvalid ? "is-invalid" : "is-valid";
                    errorMessages = isInvalid
                    ? String.Join(", ", Model.FormModelState![fieldName]!.Errors.Select(e => e.ErrorMessage))
                    : "";
                }
                <span class="input-group-text" id="user-birthdate-addon"><i class="bi bi-cake"></i></span>
                <input type="date" class="form-control @validationClass" name=@fieldName
                       value="@Model.FormModel?.UserBirthdate?.ToString("yyyy-MM-dd")"
                       placeholder="Birthdate" aria-label="Birthdate" aria-describedby="user-birthdate-addon" />
                <div class="invalid-feedback">@errorMessages</div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col">
            <div class="input-group mb-3">
                @{
                    fieldName = "user-password";
                    isInvalid = Model.FormModelState?.Keys.Contains(fieldName) ?? false;
                    validationClass = Model.FormModelState == null ? "" : isInvalid ? "is-invalid" : "is-valid";
                    errorMessages = isInvalid
                    ? String.Join(", ", Model.FormModelState![fieldName]!.Errors.Select(e => e.ErrorMessage))
                    : "";
                }
                <span class="input-group-text" id="user-password-addon"><i class="bi bi-lock"></i></span>
                <input type="password" class="form-control @validationClass" name=@fieldName
                       value="@Model.FormModel?.UserPassword"
                       placeholder="Password" aria-label="Password" aria-describedby="user-password-addon" />
                <div class="invalid-feedback">@errorMessages</div>
            </div>
        </div>
        <div class="col">
            <div class="input-group mb-3">
                @{
                    fieldName = "user-repeat";
                    isInvalid = Model.FormModelState?.Keys.Contains(fieldName) ?? false;
                    validationClass = Model.FormModelState == null ? "" : isInvalid ? "is-invalid" : "is-valid";
                    errorMessages = isInvalid
                    ? String.Join(", ", Model.FormModelState![fieldName]!.Errors.Select(e => e.ErrorMessage))
                    : "";
                }
                <span class="input-group-text" id="user-repeat-addon"><i class="bi bi-unlock"></i></span>
                <input type="password" class="form-control @validationClass" name=@fieldName
                       value="@Model.FormModel?.UserRepeat"
                       placeholder="Repeat" aria-label="Repeat" aria-describedby="user-repeat-addon" />
                <div class="invalid-feedback">@errorMessages</div>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-success" name="user-button" value="SignUp">Реєстрація</button>
</form>

@if (Model.FormModelState != null)
{
    foreach (var item in Model.FormModelState)
    {
        <p>
            @item.Key -- @String.Join(", ", item.Value.Errors.Select(e => e.ErrorMessage))
        </p>
    }
    <p>
        Передано дані @Html.DisplayFor(m => Model.FormModel)
    </p>
}

<h2>Модель</h2>
<p>
    Для прийому даних від форми створюється модель (модель форми). Розрізнення випадків
    коли форма порожня та випадків, коли взагалі немає надсилання, здійснюється шляхом
    включення до моделі форми відомостей про кнопку надсилання. Аналогічно на самій формі
    на кнопці має бути зазначені ім'я та значення.
</p>

<p>
    Для передачі даних до представлення слід створити модель, до якої включити модель
    форми для можливості відновлення попередньо заповнених даних
</p>

<p>
    Передача даних форми здійнсюється у HTTP-пакеті, що, формально є одним запитом.
    Спроби оновлення сторінки, на яку надіслані дані означає необхідність повторення запиту,
    у відповідь на який побудована дана сторінка, тобто повторрну передачу форми.
    Якщо фрома передана методом GET , то одразу відбуваеться онрвлення сторінки, якщо POST
    то видається поеренє повідомлення, оскільки повтор може бути пов'язаний з
    повторним надсиланням великих даних у т.ч. файлів.
</p>
<p>
    Частіше за все повторне надсилання POST-даних не призводить до позитивних наслідків
    У кращому випадку може вимкнути конфлікт унікальності
    У гуршому випадку дані можуть замінти або додати до вже наявних що потребує
    їх подальщого пошуку та видалення
</p>
<p>
    Аналогічна поведінка моде виникти при русі історією запитів
</p>

<h2>"Скидання" параметрів</h2>
<p>
    Сервер не може змінити параметри запиту який зафіксував браузер для оновлення
    даної сторінки. Задача "прибиання" даних форми або "Скидання" параметрів реалізується
    інструментами редиректу:
</p>
<ul>
    <li>Браузер надсилає запити з формию методом POST</li>
    <li>
        Сервер приймає дані, зберігає та надсилає браузеру статус 30х (302 Found),
        У складі якого зазначається адреса переходу (редиректу)
    </li>
    <li>
        Браузер автоматично переходить на зазначений дедирект, причому завжди методом
        GET та без параметрів
    </li>
    <li>
        Сервер відновлює збережені дані та видає результат. Спроба оновлення такої сторінки
        повторить останній з запитів, тобто GET без параметрів
    </li>
</ul>
<p>
    Складність полягає у задачі збереження між запитами,
    причому не стільки у процессі збереження скільки у співвідесені даних та
    запиту, оскільки одночасно може надходити багато різних запитів.
    Вирішення даної задачі = сесії (сеанси)
</p>
<p>
    HTTP-сесія - механизм утворення серверних сховищ які співвідносяться з записами за
    допомогою встановлення заголовків-Cookie за якими вони і розпізнаються
</p>